<h1>Add Our Story</h1>

<form action="/impact/add_data" method="POST" enctype="multipart/form-data">

    <!-- Main Section -->
    <h3>Main Section</h3>
    <div class="mb-3">
        <label class="form-label">Main Title</label>
        <input type="text" class="form-control" name="title" required>
    </div>
    <div class="mb-3">
        <label class="form-label">Main Content</label>
        <textarea class="form-control" name="content" rows="5" required></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Hero Image</label>
        <input type="file" class="form-control" name="heroImage" required>
    
    </div>

         <hr>


<div class="mb-3">
        <label class="form-label">first side Title</label>
        <input type="text" class="form-control" name="title1">
    </div>
    <div class="mb-3">
        <label class="form-label">first side Content</label>
        <textarea class="form-control" name="content1" rows="3"></textarea>
    </div>   
      <div class="mb-3">
        <label class="form-label">right Image</label>
        <input type="file" class="form-control" name="image1">
    </div>
    <!-- Building With Intention -->

<div class="mb-3">
        <label class="form-label">second side Title</label>
        <input type="text" class="form-control" name="title2">
    </div>
    <div class="mb-3">
        <label class="form-label">second side Content</label>
        <textarea class="form-control" name="content2" rows="3"></textarea>
    </div>    
 <div class="mb-3">
        <label class="form-label">left Image</label>
        <input type="file" class="form-control" name="image2">
    </div>
     
         <hr>

<!-- Measurable Progress -->
   <h3>Environmental Impact</h3>
    <div class="mb-3">
        <label class="form-label">percentage</label>
        <input type="text" class="form-control" name="title3" >
    </div>
    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" name="content3" rows="3" ></textarea>
    </div>   
      <div class="mb-3">
        <label class="form-label">Image 1</label>
        <input type="file" class="form-control" name="image3">
    </div>

   <h3>Energy Use</h3>
     <div class="mb-3">
        <label class="form-label">percentage</label>
        <input type="text" class="form-control" name="title4" >
    </div>
    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" name="content4" rows="3"></textarea>
    </div>   
      <div class="mb-3">
        <label class="form-label">Image 1</label>
        <input type="file" class="form-control" name="image4">
    </div>


   <h3>Green Compliance</h3>

    <div class="mb-3">
        <label class="form-label">percentage</label>
        <input type="text" class="form-control" name="title5">
    </div>
    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" name="content5" rows="3"></textarea>
    </div>   
      <div class="mb-3">
        <label class="form-label">Image 1</label>
        <input type="file" class="form-control" name="image5">
    </div>


   <h3>Performance Snapshot</h3>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" class="form-control" name="title6" >
    </div>
    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" name="content6" rows="3"></textarea>
    </div> 

     <hr>
 
     <!-- What Drives Us -->
     <h3>What Drives Us</h3>

     <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" class="form-control" name="title7" >
    </div>

    <h6>Energy Efficiency</h6>
    <div class="mb-3">
         <textarea class="form-control" name="content7" rows="3"></textarea>
    </div> 

    <h6>Material Responsibility</h6>
    <div class="mb-3">
         <textarea class="form-control" name="content8" rows="3"></textarea>
    </div> 

    <h6>Climate Response</h6>
    <div class="mb-3">
         <textarea class="form-control" name="content9" rows="3"></textarea>
    </div> 

    <h6>Long-Term Value</h6>

    <div class="mb-3">
         <textarea class="form-control" name="content10" rows="3"></textarea>
    </div> 

    <hr>

    <!-- last banner -->
 <div class="mb-3">
        <label class="form-label">last banner</label>
        <input type="file" class="form-control" name="image6">
    </div>
    <hr>

    <!-- Journey Sections -->
    <h3 class="mt-4">Side Section</h3>
    <div id="journeySectionsContainer">
        <!-- Javascript will inject journey sections here -->
    </div>
    
    <button type="button" id="addJourneyBtn" class="btn btn-warning mt-2">
        <i class="fas fa-plus"></i> Add Section
    </button>

    <div class="mt-4 mb-5">
        <button type="submit" class="btn btn-primary">
            Submit Story
        </button>
    </div>
</form>

