<h1>Edit Story</h1>

<form action="/ourstory/edit/<%= story._id %>" method="POST" enctype="multipart/form-data">
    <!-- Main Section -->
    <h3>Main Section</h3>
    <div class="mb-3">
        <label class="form-label">Main Title</label>
        <input type="text" class="form-control" name="title" value="<%= story.title %>" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Main Content</label>
        <textarea class="form-control" name="content" rows="5" required><%= story.content %></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Hero Image</label>
        <% if (story.heroImage) { %>
            <div class="mb-2">
                <img src="<%= story.heroImage %>" alt="Current Hero Image" style="max-width: 200px;">
            </div>
        <% } %>
        <input type="file" class="form-control" name="heroImage">
        <small class="text-muted">Leave empty to keep the current image.</small>
    </div>

    <!-- Section 1 -->
    <h3 class="mt-4">Section 1</h3>
    <div class="mb-3">
        <label class="form-label">Title 1</label>
        <input type="text" class="form-control" name="title1" value="<%= story.title1 || '' %>">
    </div>
    <div class="mb-3">
        <label class="form-label">Content 1</label>
        <textarea class="form-control" name="content1" rows="3"><%= story.content1 || '' %></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Image 1</label>
        <% if (story.image1) { %>
            <div class="mb-2">
                <img src="<%= story.image1 %>" alt="Current Image 1" style="max-width: 200px;">
            </div>
        <% } %>
        <input type="file" class="form-control" name="image1">
    </div>

    <!-- Section 2 -->
    <h3 class="mt-4">Section 2</h3>
    <div class="mb-3">
        <label class="form-label">Title 2</label>
        <input type="text" class="form-control" name="title2" value="<%= story.title2 || '' %>">
    </div>
    <div class="mb-3">
        <label class="form-label">Content 2</label>
        <textarea class="form-control" name="content2" rows="3"><%= story.content2 || '' %></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Image 2</label>
        <% if (story.image2) { %>
            <div class="mb-2">
                <img src="<%= story.image2 %>" alt="Current Image 2" style="max-width: 200px;">
            </div>
        <% } %>
        <input type="file" class="form-control" name="image2">
    </div>

    <!-- Section 3 -->
    <h3 class="mt-4">Section 3</h3>
    <div class="mb-3">
        <label class="form-label">Title 3</label>
        <input type="text" class="form-control" name="title3" value="<%= story.title3 || '' %>">
    </div>
    <div class="mb-3">
        <label class="form-label">Content 3</label>
        <textarea class="form-control" name="content3" rows="3"><%= story.content3 || '' %></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Image 3</label>
        <% if (story.image3) { %>
            <div class="mb-2">
                <img src="<%= story.image3 %>" alt="Current Image 3" style="max-width: 200px;">
            </div>
        <% } %>
        <input type="file" class="form-control" name="image3">
    </div>

    <!-- Dynamic Sections -->
    <h3 class="mt-4">Extra Sections</h3>
    <div id="dynamicSectionsContainer">
        <% if (story.dynamicSections && story.dynamicSections.length > 0) { %>
            <% story.dynamicSections.forEach((section, index) => { %>
                <div class="card p-3 mb-3 border border-info">
                    <div class="d-flex justify-content-between">
                        <h5>Extra Section <%= index + 1 %></h5>
                        <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.parentElement.remove()">Remove</button>
                    </div>
                    <input type="hidden" name="existingDynamicImages[]" value="<%= section.image %>">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" name="dynamicNames[]" value="<%= section.name %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Post</label>
                        <input type="text" class="form-control" name="dynamicPosts[]" value="<%= section.post %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea class="form-control" name="dynamicContents[]" rows="3"><%= section.content %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image</label>
                        <% if (section.image) { %>
                            <div class="mb-2">
                                <img src="<%= section.image %>" alt="Image" style="max-width: 150px;">
                            </div>
                        <% } %>
                        <input type="file" class="form-control" name="dynamicImage_<%= index %>">
                        <small class="text-muted">Leave empty to keep the current image.</small>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
    
    <button type="button" id="addSectionBtn" class="btn btn-info mt-2">
        <i class="fas fa-plus"></i> Add +
    </button>

    <!-- Journey Sections -->
    <h3 class="mt-4">Journey Section</h3>
    <div id="journeySectionsContainer">
        <% if (story.journeySections && story.journeySections.length > 0) { %>
            <% story.journeySections.forEach((section, index) => { %>
                <div class="card p-3 mb-3 border border-warning">
                    <div class="d-flex justify-content-between">
                        <h5>Journey <%= index + 1 %></h5>
                        <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.parentElement.remove()">Remove</button>
                    </div>
                    <input type="hidden" name="existingJourneyImages[]" value="<%= section.image %>">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" name="journeyTitles[]" value="<%= section.title %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea class="form-control" name="journeyContents[]" rows="3"><%= section.content %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image</label>
                        <% if (section.image) { %>
                            <div class="mb-2">
                                <img src="<%= section.image %>" alt="Image" style="max-width: 150px;">
                            </div>
                        <% } %>
                        <input type="file" class="form-control" name="journeyImage_<%= index %>">
                        <small class="text-muted">Leave empty to keep the current image.</small>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
    
    <button type="button" id="addJourneyBtn" class="btn btn-warning mt-2">
        <i class="fas fa-plus"></i> Add Journey
    </button>

    <div class="mt-4 mb-5">
        <button type="submit" class="btn btn-primary">
            Update Story
        </button>
        <a href="/ourstory" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<script>
    let sectionCount = <%= story.dynamicSections ? story.dynamicSections.length : 0 %>;
    document.getElementById('addSectionBtn').addEventListener('click', function() {
        const container = document.getElementById('dynamicSectionsContainer');
        const sectionHtml = `
            <div class="card p-3 mb-3 border border-info">
                <div class="d-flex justify-content-between">
                    <h5>New Extra Section</h5>
                    <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.parentElement.remove()">Remove</button>
                </div>
                <input type="hidden" name="existingDynamicImages[]" value="">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" name="dynamicNames[]" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Post</label>
                    <input type="text" class="form-control" name="dynamicPosts[]">
                </div>
                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea class="form-control" name="dynamicContents[]" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Image</label>
                    <input type="file" class="form-control" name="dynamicImage_${sectionCount}" required>
                </div>
            </div>
        `;
        container.insertAdjacentHTML('beforeend', sectionHtml);
        sectionCount++;
    });

    let journeyCount = <%= story.journeySections ? story.journeySections.length : 0 %>;
    document.getElementById('addJourneyBtn').addEventListener('click', function() {
        const container = document.getElementById('journeySectionsContainer');
        const sectionHtml = `
            <div class="card p-3 mb-3 border border-warning">
                <div class="d-flex justify-content-between">
                    <h5>New Journey</h5>
                    <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.parentElement.remove()">Remove</button>
                </div>
                <input type="hidden" name="existingJourneyImages[]" value="">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" name="journeyTitles[]" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea class="form-control" name="journeyContents[]" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Image</label>
                    <input type="file" class="form-control" name="journeyImage_${journeyCount}" required>
                </div>
            </div>
        `;
        container.insertAdjacentHTML('beforeend', sectionHtml);
        journeyCount++;
    });
</script>