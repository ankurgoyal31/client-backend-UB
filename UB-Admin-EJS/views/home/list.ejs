<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold">Manage Home</h4>
  <% if(home_data.length <= 0) {%>
            <a href="/home/addform" class="btn btn-primary">Add Home</a>
    <% }%>
    <!-- <a href="/ourstory/addform" class="btn btn-primary">Add Home</a> -->
</div>

<table class="table table-bordered table-striped">
  <thead>
    <tr>
      <th>Count</th>
      <th>Title</th>
      <th>Content</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (home_data && home_data.length > 0) { %>
      <% home_data.forEach((story,i) => { %>
        <tr>
          <td>
            <%= i+1 %> 
          </td>
          <td><%= story.title %></td>
          <td><%= story.content.length > 50 ? story.content.substring(0, 50) + '...' : story.content %></td>
          <td>
            <a href="/home/editform/<%= story._id %>" class="btn btn-sm btn-warning">Edit</a>


               <form action="/home/delete/<%= story._id %>?_method=DELETE" 
                          method="POST" 
                          class="d-inline">
                       <button class="btn btn-sm btn-danger"
                               onclick="return confirm('Delete this project?')">
                         Delete
                       </button>
                     </form>
          </td>

        </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td colspan="4" class="text-center">No home data found.</td>
      </tr>
    <% } %>
  </tbody>
</table>
